# Copy this file to `.Renviron` (which is gitignored) and edit the values below.
# `.Renviron` is read by R at startup.

# Which data to read from. `mock` is the default and the only mode safe to share.
# Set to `real` only when you're running the analysis against your raw data.
DATA_MODE=mock

# Optional: path to raw data if it lives outside the repo (e.g., on a network drive).
# Leave empty to use `data/raw/` inside the repo.
RAW_DATA_DIR=

# Optional: pandoc / quarto paths if your install is non-standard.
# QUARTO_PATH=/usr/local/bin/quarto
